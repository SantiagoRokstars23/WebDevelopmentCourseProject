# =====================================================
# VARIABLES DE ENTORNO - Configuración del proyecto
# =====================================================
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a ".env"
#   2. Rellena los valores con tus credenciales reales
#   3. NUNCA subas el archivo .env a Git (ya está en .gitignore)
#
# Para copiar: cp .env.example .env
# =====================================================

# Puerto del servidor Express
PORT=3000

# Configuración de PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=admin
DB_PASSWORD=admin123
